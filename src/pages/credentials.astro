---
import BaseLayout from '../layouts/BaseLayout.astro';
import { credentialGroups, primaryCredentials } from '../data/portfolio';
---

<BaseLayout
  title="Credentials | Nazeem Dickey"
  description="Verified primary certifications, additional credentials, education, and recognition for Nazeem Dickey."
>
  <main id="main" tabindex="-1">
    <header class="page-hero page-hero--compact">
      <div class="page-hero__side">
        <p class="eyebrow eyebrow--signal">Credentials / verified</p>
        <p>Primary certifications are separated from stackable titles, fundamentals exams, and course badges.</p>
      </div>
      <h1>Every primary certification links to public verification.</h1>
    </header>

    <section class="content-section credentials-primary">
      <div class="credentials-lead">
        <strong>{primaryCredentials.length}</strong>
        <div>
          <p class="eyebrow">Primary certifications</p>
          <h2>The credentials most relevant to IT support, networking, and security foundations.</h2>
          <p>Use the verification link on each card, or view the complete record on <a href="https://www.credly.com/users/nazeem-dickey/badges" target="_blank" rel="noreferrer">Credly</a>.</p>
        </div>
      </div>

      <div class="verified-credential-grid" aria-label="Verified primary certifications">
        {primaryCredentials.map((credential) => (
          <article class="verified-credential">
            <div>
              <p class="eyebrow">{credential.issuer} / {credential.year}</p>
              <h2>{credential.name}</h2>
              <p>{credential.area}</p>
            </div>
            <a class="text-link" href={credential.verify} target="_blank" rel="noreferrer">Verify on Credly ↗</a>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section" aria-labelledby="additional-credentials-title">
      <div class="section-heading">
        <div class="section-heading__side">
          <p class="eyebrow">Additional record</p>
          <p>Listed separately so the primary certifications are not counted twice.</p>
        </div>
        <div class="section-heading__main"><h2 id="additional-credentials-title">Fundamentals, stackable titles, and course badges.</h2></div>
      </div>
      <div class="credential-grid" aria-label="Additional credential groups">
        {credentialGroups.map((group, index) => (
          <article class="credential-group">
            <p class="eyebrow">{String(index + 1).padStart(2, '0')} / {group.issuer}</p>
            <h3>{group.issuer}</h3>
            <p>{group.summary}</p>
            <ul>{group.items.map((item) => <li>{item}</li>)}</ul>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section" aria-labelledby="recognition-title">
      <div class="section-heading">
        <div class="section-heading__side"><p class="eyebrow">Education & recognition</p></div>
        <div class="section-heading__main"><h2 id="recognition-title">Where the work was <em>tested.</em></h2></div>
      </div>
      <div class="timeline">
        <article class="timeline-item">
          <time>May 2026</time><h3>SouthTech Academy</h3>
          <p>Graduate. Honor Roll, honors classes, and Esports Team Captain in Boynton Beach, Florida.</p>
        </article>
        <article class="timeline-item">
          <time>Apr 2026</time><h3>SkillsUSA Florida</h3>
          <p>Gold medal and first place in the state Internetworking competition.</p>
        </article>
        <article class="timeline-item">
          <time>Jun 2026</time><h3>SkillsUSA NLSC</h3>
          <p>National Internetworking competitor in Atlanta; converted the experience into a focused Cisco IOS practice system.</p>
        </article>
        <article class="timeline-item">
          <time>Apr 2026</time><h3>CyberLaunch USF</h3>
          <p>Advanced from the virtual qualifier to Florida’s in-person high school cybersecurity state championship.</p>
        </article>
      </div>
    </section>
  </main>
</BaseLayout>
