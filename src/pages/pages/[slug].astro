---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactCTA from '../../components/ContactCTA.astro';
import { projects, type Project } from '../../data/projects';
import { writeups } from '../../data/writeups';
import { site } from '../../data/site';

export function getStaticPaths() {
  return projects
    .filter(project => project.slug !== 'status')
    .map(project => ({ params: { slug: project.slug }, props: { project } }));
}

type Props = {
  project: Project;
};

const { project } = Astro.props;
const relatedWriteups = writeups.filter(writeup =>
  project.relatedWriteups?.includes(writeup.slug) || writeup.relatedProjects.includes(project.slug)
);

const diagrams: Record<string, string> = {
  'ai-automation': '/assets/diagrams/ai-automation-diagram.svg',
  'ai-gateway': '/assets/diagrams/ai-gateway-diagram.svg',
  'game-hosting': '/assets/diagrams/game-hosting-diagram.svg',
  homelab: '/assets/diagrams/network-diagram.svg',
  identity: '/assets/diagrams/identity-diagram.svg',
  'mcp-server': '/assets/diagrams/mcp-server-diagram.svg',
  opnsense: '/assets/diagrams/opnsense-diagram.svg',
  proxmox: '/assets/diagrams/proxmox-diagram.svg',
  'remote-access': '/assets/diagrams/remote-access-diagram.svg',
  skillsusa: '/assets/diagrams/skillsusa-diagram.svg',
  switching: '/assets/diagrams/switching-diagram.svg',
  'vlan-segmentation': '/assets/diagrams/vlan-segmentation-diagram.svg',
  wazuh: '/assets/diagrams/wazuh-diagram.svg',
};

const diagram = diagrams[project.slug];
---

<BaseLayout
  title={`${project.title} | ${site.name}`}
  description={project.summary}
>
  <section class="page-hero">
    <span class="eyebrow">{project.eyebrow}</span>
    <h1>{project.title}</h1>
    <p class="lead">{project.summary}</p>
    <ul class="tag-list">
      {project.rolePaths.map(role => <li>{role}</li>)}
      {project.categories.map(category => <li>{category}</li>)}
    </ul>
  </section>

  {diagram && (
    <section class="section">
      <div class="card media-panel">
        <img class="diagram" src={diagram} alt={`${project.title} architecture diagram`} loading="lazy" />
      </div>
    </section>
  )}

  {project.slug === 'homelab' && (
    <section class="section">
      <div class="grid three">
        <img class="site-photo" src="/assets/images/rack-full.jpg" alt="Homelab rack front view" loading="lazy" />
        <img class="site-photo" src="/assets/images/rack-interior.jpg" alt="Homelab rack interior" loading="lazy" />
        <img class="site-photo" src="/assets/images/rack-back-cables.jpg" alt="Homelab rack cabling" loading="lazy" />
      </div>
    </section>
  )}

  <section class="section">
    <div class="grid two">
      <article class="card">
        <span class="mini-label">Problem</span>
        <h2>Why it mattered</h2>
        <p>{project.problem}</p>
      </article>
      <article class="card">
        <span class="mini-label">Result</span>
        <h2>What changed</h2>
        <p>{project.result}</p>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="grid two">
      <article class="card">
        <span class="mini-label">What I Built</span>
        <h2>Build summary</h2>
        <ul class="clean-list">
          {project.built.map(item => <li>{item}</li>)}
        </ul>
      </article>
      <article class="card">
        <span class="mini-label">Skills Shown</span>
        <h2>Practical skills</h2>
        <ul class="tag-list cert-list">
          {project.skills.map(skill => <li>{skill}</li>)}
        </ul>
      </article>
    </div>
  </section>

  {project.slug === 'skillsusa' && (
    <section class="section">
      <div class="card nationals-countdown">
        <span class="mini-label" id="cdLabel">NLSC Nationals — Atlanta, GA</span>
        <h2 id="cdHeading">Competed at NLSC Nationals</h2>
        <p class="lead" id="cdLead">Atlanta, GA &bull; June 1&ndash;6, 2026 &bull; 6,500+ state champions from 114 events nationwide.</p>
        <div class="countdown-grid is-hidden" id="nationalsCountdown">
          <div class="countdown-cell"><span class="countdown-num" id="cdDays">--</span><span class="countdown-label">Days</span></div>
          <div class="countdown-cell"><span class="countdown-num" id="cdHours">--</span><span class="countdown-label">Hours</span></div>
          <div class="countdown-cell"><span class="countdown-num" id="cdMins">--</span><span class="countdown-label">Mins</span></div>
          <div class="countdown-cell"><span class="countdown-num" id="cdSecs">--</span><span class="countdown-label">Secs</span></div>
        </div>
      </div>
    </section>
  )}

  {relatedWriteups.length > 0 && (
    <section class="section">
      <div class="section-header">
        <div>
          <span class="mini-label">Related Writeups</span>
          <h2>Notes connected to this project</h2>
        </div>
      </div>
      <div class="grid three">
        {relatedWriteups.map(writeup => (
          <article class="card">
            <span class="project-type">{writeup.category} - {writeup.date}</span>
            <h3>{writeup.title}</h3>
            <p>{writeup.summary}</p>
            <a class="card-link" href={writeup.href}>Read writeup</a>
          </article>
        ))}
      </div>
    </section>
  )}

  <section class="section">
    <a class="button secondary" href="/pages/projects.html">Back to project hub</a>
  </section>

  <ContactCTA />
</BaseLayout>

<style>
  .nationals-countdown {
    border-left: 3px solid var(--accent-strong);
  }

  .countdown-grid {
    display: flex;
    gap: 12px;
    margin-top: 20px;
  }

  .countdown-grid.is-hidden {
    display: none;
  }

  .countdown-cell {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 72px;
    padding: 14px 10px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--bg-soft);
  }

  .countdown-num {
    font-size: 2rem;
    font-weight: 950;
    color: var(--accent);
    line-height: 1;
  }

  .countdown-label {
    margin-top: 4px;
    font-size: 0.62rem;
    font-weight: 800;
    color: var(--subtle);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
</style>

<script is:inline>
  (() => {
    const end = new Date('2026-06-06T23:59:59');
    const now = new Date();
    // After event: static HTML defaults are correct — nothing to do.
    if (now >= end) return;

    // Before or during event: switch to countdown mode.
    const wrap = document.getElementById('nationalsCountdown');
    const label = document.getElementById('cdLabel');
    const heading = document.getElementById('cdHeading');
    const lead = document.getElementById('cdLead');
    const dEl = document.getElementById('cdDays');
    const hEl = document.getElementById('cdHours');
    const mEl = document.getElementById('cdMins');
    const sEl = document.getElementById('cdSecs');
    if (!wrap) return;

    if (label) label.textContent = 'Next Up';
    if (heading) heading.textContent = 'SkillsUSA NLSC Nationals — Atlanta, GA';
    if (lead) lead.textContent = 'June 1–6, 2026 • Competing against 6,500+ state champions nationwide.';
    wrap.classList.remove('is-hidden');

    const target = new Date('2026-06-01T08:00:00');
    function pad(n) { return String(n).padStart(2, '0'); }

    function tick() {
      let diff = Math.max(target - new Date(), 0);
      const days = Math.floor(diff / 86400000); diff %= 86400000;
      const hours = Math.floor(diff / 3600000); diff %= 3600000;
      const mins = Math.floor(diff / 60000); diff %= 60000;
      const secs = Math.floor(diff / 1000);
      if (dEl) dEl.textContent = String(days);
      if (hEl) hEl.textContent = pad(hours);
      if (mEl) mEl.textContent = pad(mins);
      if (sEl) sEl.textContent = pad(secs);
    }

    tick();
    setInterval(tick, 1000);
  })();
</script>
