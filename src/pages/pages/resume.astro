---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactCTA from '../../components/ContactCTA.astro';
import { site, rolePaths } from '../../data/site';
---

<BaseLayout
  title={`Resume | ${site.name}`}
  description="Resume downloads and role-fit links for Nazeem Massoom Dickey."
>
  <section class="page-hero">
    <span class="eyebrow">Resume</span>
    <h1>Resume and fast proof links.</h1>
    <p class="lead">
      Download the PDF or jump into projects that show the work behind the bullet points.
    </p>
    <div class="button-row">
      <a class="button" href="/assets/resumes/Massoom_Dickey_Nazeem_Resume.pdf">Download Resume</a>
      <a class="button secondary" href="/pages/Massoom_Dickey_Nazeem_Resume.html">View Resume</a>
      <a class="button secondary" href="/pages/projects.html">Project hub</a>
    </div>
  </section>

  <section class="section">
    <div class="grid four">
      {rolePaths.map(path => (
        <article class="card proof-card">
          <strong>{path.title}</strong>
          <p>{path.summary}</p>
          <a class="card-link" href={path.href}>Explore {path.title} →</a>
        </article>
      ))}
    </div>
  </section>

  <ContactCTA />
</BaseLayout>
