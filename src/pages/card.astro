---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';
---

<BaseLayout
  title="Nazeem Massoom Dickey — Digital Card"
  description="IT & Cybersecurity candidate. 31 certifications, SkillsUSA Florida Internetworking 1st Place, enterprise homelab. Junior Network Admin / SOC / NOC."
  canonical="https://masternazz.com/card"
>
  <div class="card-page">

    <div class="biz-card">

      <!-- gradient top bar -->
      <div class="biz-card-bar"></div>

      <div class="biz-card-inner">

        <!-- LEFT: identity + QR + badge -->
        <div class="biz-left">

          <!-- mobile: QR + name stacked -->
          <div class="mobile-top">
            <div class="qr-wrap" id="qrMobile" data-action="open-qr" style="cursor:pointer">
              <div id="qrCanvasMobile"></div>
              <div class="qr-logo">ND</div>
            </div>
            <p class="qr-hint">Tap to expand</p>
            <div class="mobile-identity">
              <div class="avatar">ND</div>
              <h1 class="card-name">Nazeem Massoom Dickey</h1>
              <p class="card-role">Network &amp; Security &bull; NOC / SOC</p>
              <p class="card-loc">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                Boynton Beach, FL
              </p>
            </div>
          </div>

          <!-- desktop: header -->
          <div class="desktop-header">
            <div class="avatar">ND</div>
            <div>
              <h1 class="card-name">Nazeem Massoom Dickey</h1>
              <p class="card-role">Network &amp; Security &bull; NOC / SOC</p>
              <p class="card-loc">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                Boynton Beach, FL
              </p>
            </div>
          </div>

          <!-- open to work -->
          <div class="otw-chip">
            <span class="otw-dot"></span>
            Open to internships &amp; entry-level IT roles
          </div>

          <!-- desktop QR -->
          <div class="qr-block desktop-qr">
            <div class="qr-wrap" id="qrDesktop" data-action="open-qr" style="cursor:pointer" title="Click to expand">
              <div id="qrCanvasDesktop"></div>
              <div class="qr-logo">ND</div>
            </div>
            <p class="qr-label">Scan to open &bull; click to expand</p>
          </div>

          <!-- SkillsUSA badge -->
          <div class="badge-card">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--amber)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <div>
              <p class="badge-title">SkillsUSA Florida — Internetworking</p>
              <p class="badge-sub">1st Place &bull; Gold Medal &bull; 2026</p>
            </div>
          </div>

        </div>

        <!-- RIGHT: links + certs + skills + actions -->
        <div class="biz-right">

          <!-- links -->
          <div class="link-list">
            <a href="https://masternazz.com" class="link-row" target="_blank" rel="noopener noreferrer">
              <div class="link-icon">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
              </div>
              <div class="link-body">
                <span class="link-label">Portfolio</span>
                <span class="link-val">masternazz.com</span>
              </div>
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="var(--subtle)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </a>

            <a href={site.linkedin} class="link-row" target="_blank" rel="noopener noreferrer">
              <div class="link-icon">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="var(--accent)"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
              </div>
              <div class="link-body">
                <span class="link-label">LinkedIn</span>
                <span class="link-val">in/nazeemdickey</span>
              </div>
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="var(--subtle)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </a>

            <button class="link-row" id="emailCopyBtn" type="button">
              <div class="link-icon">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </div>
              <div class="link-body">
                <span class="link-label">Email</span>
                <span class="link-val" id="emailVal">{site.email}</span>
              </div>
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="var(--subtle)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            </button>

            <a href={site.github} class="link-row" target="_blank" rel="noopener noreferrer">
              <div class="link-icon">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="var(--accent)"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
              </div>
              <div class="link-body">
                <span class="link-label">GitHub</span>
                <span class="link-val">github.com/masternazz</span>
              </div>
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="var(--subtle)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </a>
          </div>

          <div class="divider"></div>

          <!-- certifications -->
          <div>
            <p class="sec-label">Certifications</p>
            <div class="chip-row">
              <span class="chip">CompTIA A+</span>
              <span class="chip">Network+</span>
              <span class="chip">Security+</span>
              <span class="chip">CySA+</span>
              <span class="chip">CSAP</span>
              <span class="chip">CSIS</span>
              <span class="chip">CIOS</span>
              <span class="chip">Cisco CCST Net</span>
              <span class="chip">Cisco CCST Cyber</span>
              <span class="chip">AZ-900</span>
              <span class="chip chip-more">+22 more</span>
            </div>
          </div>

          <!-- skills -->
          <div>
            <p class="sec-label">Skills</p>
            <div class="chip-row">
              <span class="chip skill">OPNsense</span>
              <span class="chip skill">Proxmox VE</span>
              <span class="chip skill">VLAN / 802.1Q</span>
              <span class="chip skill">Wazuh SIEM</span>
              <span class="chip skill">Cloudflare</span>
              <span class="chip skill">Linux</span>
              <span class="chip skill">Docker</span>
              <span class="chip skill">Node.js</span>
            </div>
          </div>

          <div class="divider"></div>

          <!-- save contact -->
          <button class="save-btn" id="saveContactBtn" type="button">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            Save Contact
          </button>

          <!-- actions -->
          <div class="action-row">
            <a href="/pages/resume.html" class="button secondary">Resume</a>
            <a href="/pages/certifications.html" class="button secondary">All Certs</a>
            <button class="button secondary" id="shareBtn" type="button">Share</button>
          </div>

        </div>

      </div>
    </div>

    <p class="share-hint">masternazz.com/card &mdash; share this link or scan the QR above</p>

  </div>

  <!-- QR expand modal -->
  <div class="qr-modal" id="qrModal">
    <div class="qr-modal-inner" id="qrModalInner">
      <div style="position:relative;line-height:0">
        <div id="qrModalCanvas"></div>
        <div class="qr-logo qr-modal-logo">ND</div>
      </div>
      <p class="qr-modal-url">masternazz.com/card</p>
    </div>
    <p class="qr-modal-hint">Tap anywhere to close</p>
  </div>

</BaseLayout>

<style>
  .card-page {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
    padding-bottom: 24px;
  }

  .biz-card {
    width: min(900px, 100%);
    border: 1px solid var(--line);
    border-radius: 16px;
    background: var(--panel);
    box-shadow: var(--shadow);
    overflow: hidden;
  }

  .biz-card-bar {
    height: 3px;
    background: linear-gradient(90deg, #8b5cf6, #b779ff, #22c55e);
  }

  .biz-card-inner {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 0 32px;
    padding: 28px 28px 24px;
  }

  /* LEFT */
  .biz-left {
    display: flex;
    flex-direction: column;
    gap: 18px;
    border-right: 1px solid var(--line);
    padding-right: 28px;
  }

  .mobile-top { display: none; }

  .desktop-header {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }

  .avatar {
    width: 52px;
    height: 52px;
    flex-shrink: 0;
    border-radius: 10px;
    background: linear-gradient(135deg, #c084fc, #8b5cf6);
    display: grid;
    place-items: center;
    font-weight: 950;
    font-size: 1.15rem;
    color: #08070c;
    letter-spacing: -0.02em;
  }

  .card-name {
    font-size: 1rem;
    font-weight: 800;
    color: var(--text);
    margin: 0 0 3px;
    line-height: 1.25;
    letter-spacing: -0.02em;
  }

  .card-role {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0;
  }

  .card-loc {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 0.7rem;
    color: var(--subtle);
    margin: 4px 0 0;
  }

  .otw-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    align-self: flex-start;
    padding: 5px 11px;
    border: 1px solid rgba(34, 197, 94, 0.3);
    border-radius: 999px;
    background: rgba(34, 197, 94, 0.09);
    font-size: 0.68rem;
    font-weight: 700;
    color: var(--green);
    white-space: nowrap;
  }

  .otw-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--green);
    flex-shrink: 0;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.7); }
  }

  .qr-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .qr-wrap {
    position: relative;
    width: 148px;
    height: 148px;
    border-radius: 12px;
    background: #fff;
    padding: 8px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .qr-wrap canvas,
  .qr-wrap img {
    width: 132px !important;
    height: 132px !important;
    display: block;
  }

  .qr-logo {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 30px;
    height: 30px;
    border-radius: 6px;
    background: #7c3aed;
    display: grid;
    place-items: center;
    font-weight: 950;
    font-size: 0.58rem;
    color: #fff;
    pointer-events: none;
    z-index: 2;
    box-shadow: 0 2px 8px rgba(0,0,0,0.45);
  }

  .qr-label {
    font-size: 0.62rem;
    color: var(--subtle);
    text-align: center;
    margin: 0;
  }

  .qr-hint {
    font-size: 0.6rem;
    color: var(--subtle);
    text-align: center;
    margin: 2px 0 0;
    opacity: 0.7;
  }

  .badge-card {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    border: 1px solid rgba(245, 158, 11, 0.25);
    border-radius: 10px;
    background: rgba(245, 158, 11, 0.07);
  }

  .badge-title {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--amber);
    margin: 0;
    line-height: 1.3;
  }

  .badge-sub {
    font-size: 0.64rem;
    color: var(--subtle);
    margin: 3px 0 0;
    line-height: 1.3;
  }

  /* RIGHT */
  .biz-right {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .link-list {
    display: flex;
    flex-direction: column;
    gap: 7px;
  }

  .link-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 12px;
    border: 1px solid var(--line);
    border-radius: 10px;
    background: rgba(183, 121, 255, 0.04);
    color: var(--text);
    font: inherit;
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    text-align: left;
    width: 100%;
    transition: background 0.15s, border-color 0.15s, transform 0.15s;
    text-decoration: none;
  }

  .link-row:hover {
    background: rgba(183, 121, 255, 0.1);
    border-color: var(--line-strong);
    transform: translateX(3px);
  }

  .link-icon {
    width: 28px;
    height: 28px;
    flex-shrink: 0;
    border-radius: 7px;
    border: 1px solid var(--line);
    background: var(--bg-soft);
    display: grid;
    place-items: center;
  }

  .link-body {
    flex: 1;
    min-width: 0;
  }

  .link-label {
    display: block;
    font-size: 0.62rem;
    color: var(--subtle);
    font-weight: 500;
    line-height: 1;
    margin-bottom: 2px;
  }

  .link-val {
    display: block;
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    line-height: 1.3;
  }

  .divider {
    height: 1px;
    background: var(--line);
  }

  .sec-label {
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--subtle);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0 0 8px;
  }

  .chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
  }

  .chip {
    padding: 3px 9px;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: var(--bg-soft);
    font-size: 0.67rem;
    font-weight: 700;
    color: var(--muted);
    white-space: nowrap;
  }

  .chip.skill {
    border-color: rgba(183, 121, 255, 0.2);
    background: rgba(183, 121, 255, 0.07);
    color: var(--muted);
  }

  .chip-more {
    color: var(--accent);
    border-color: rgba(183, 121, 255, 0.3);
    background: rgba(183, 121, 255, 0.08);
  }

  .save-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 13px;
    border: none;
    border-radius: 10px;
    background: linear-gradient(135deg, #c084fc, #8b5cf6);
    color: #08070c;
    font: inherit;
    font-size: 0.84rem;
    font-weight: 800;
    cursor: pointer;
    transition: opacity 0.15s, transform 0.15s;
    box-shadow: 0 6px 20px rgba(139, 92, 246, 0.3);
  }

  .save-btn:hover {
    opacity: 0.9;
    transform: translateY(-2px);
  }

  .action-row {
    display: flex;
    gap: 8px;
  }

  .action-row .button {
    flex: 1;
    font-size: 0.76rem;
    padding: 9px 8px;
    text-align: center;
  }

  .share-hint {
    font-size: 0.68rem;
    color: var(--subtle);
    text-align: center;
    margin: 0;
  }

  /* QR modal */
  .qr-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 400;
    background: rgba(0,0,0,0.82);
    backdrop-filter: blur(8px);
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 20px;
    cursor: pointer;
  }

  .qr-modal.is-open {
    display: flex;
  }

  .qr-modal-inner {
    background: #fff;
    border-radius: 18px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    position: relative;
    cursor: default;
    box-shadow: 0 24px 80px rgba(0,0,0,0.6);
  }

  .qr-modal-inner canvas,
  .qr-modal-inner img {
    width: 260px !important;
    height: 260px !important;
    display: block;
  }

  .qr-modal-logo {
    width: 46px;
    height: 46px;
    border-radius: 9px;
    font-size: 0.85rem;
  }

  .qr-modal-url {
    font-size: 0.76rem;
    color: #475569;
    font-weight: 600;
    letter-spacing: 0.02em;
    margin: 0;
  }

  .qr-modal-hint {
    font-size: 0.68rem;
    color: rgba(255,255,255,0.45);
    letter-spacing: 0.04em;
    margin: 0;
  }

  /* mobile layout */
  @media (max-width: 640px) {
    .biz-card-inner {
      grid-template-columns: 1fr;
      padding: 20px 18px;
      gap: 20px 0;
    }

    .biz-left {
      border-right: none;
      border-bottom: 1px solid var(--line);
      padding-right: 0;
      padding-bottom: 20px;
    }

    .desktop-header,
    .desktop-qr { display: none; }

    .mobile-top {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12px;
      text-align: center;
    }

    .mobile-top .qr-wrap {
      width: 120px;
      height: 120px;
      padding: 7px;
    }

    .mobile-top .qr-wrap canvas,
    .mobile-top .qr-wrap img {
      width: 106px !important;
      height: 106px !important;
    }

    .mobile-top .qr-logo {
      width: 26px;
      height: 26px;
      font-size: 0.54rem;
    }

    .mobile-identity .avatar {
      margin: 0 auto 8px;
    }

    .mobile-identity .card-loc {
      justify-content: center;
    }

    .otw-chip {
      align-self: center;
      font-size: 0.64rem;
      white-space: normal;
      text-align: center;
    }
  }
</style>

<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js" crossorigin="anonymous"></script>
<script is:inline>
  (() => {
    const CARD_URL = 'https://masternazz.com/card';

    function makeQR(el, size) {
      if (!el || typeof QRCode === 'undefined') return;
      el.innerHTML = '';
      new QRCode(el, {
        text: CARD_URL,
        width: size,
        height: size,
        colorDark: '#000000',
        colorLight: '#ffffff',
        correctLevel: QRCode.CorrectLevel.H,
      });
    }

    function buildAll() {
      makeQR(document.getElementById('qrCanvasDesktop'), 260);
      makeQR(document.getElementById('qrCanvasMobile'), 200);
    }

    document.addEventListener('DOMContentLoaded', buildAll);

    // QR modal
    const modal = document.getElementById('qrModal');
    const modalCanvas = document.getElementById('qrModalCanvas');

    function openModal() {
      makeQR(modalCanvas, 520);
      modal.classList.add('is-open');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      modal.classList.remove('is-open');
      document.body.style.overflow = '';
    }

    document.querySelectorAll('[data-action="open-qr"]').forEach(el => {
      el.addEventListener('click', openModal);
    });

    modal.addEventListener('click', e => {
      if (e.target === modal) closeModal();
    });

    document.addEventListener('keydown', e => {
      if (e.key === 'Escape') closeModal();
    });

    // Copy email
    const emailBtn = document.getElementById('emailCopyBtn');
    const emailVal = document.getElementById('emailVal');
    if (emailBtn && emailVal) {
      emailBtn.addEventListener('click', () => {
        navigator.clipboard.writeText('nazeemdickey@masternazz.com').then(() => {
          emailVal.textContent = 'Copied!';
          setTimeout(() => { emailVal.textContent = 'nazeemdickey@masternazz.com'; }, 2000);
        });
      });
    }

    // Save contact (vCard)
    document.getElementById('saveContactBtn').addEventListener('click', () => {
      const vcf = [
        'BEGIN:VCARD',
        'VERSION:3.0',
        'FN:Nazeem Massoom Dickey',
        'N:Massoom Dickey;Nazeem;;;',
        'TITLE:IT & Cybersecurity Candidate',
        'ORG:Open to Opportunities',
        'EMAIL;TYPE=INTERNET:nazeemdickey@masternazz.com',
        'URL:https://masternazz.com',
        'URL;TYPE=LinkedIn:https://www.linkedin.com/in/nazeemdickey/',
