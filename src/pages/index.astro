---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { capabilities, experience, featuredProjects, profile } from '../data/portfolio';
---

<BaseLayout>
  <main id="main" class="home" tabindex="-1">
    <section class="home-intro" aria-labelledby="hero-title">
      <div class="home-intro__copy">
        <p class="eyebrow eyebrow--signal">Entry-level IT support + network technician / Boynton Beach, Florida</p>
        <h1 id="hero-title">I troubleshoot everyday IT problems and build networks at home.</h1>
        <p class="hero__lede">
          Through freelance support, I have set up home routers and fixed connectivity, hardware, and DNS problems. I also run a
          three-node Proxmox lab and practice Cisco IOS because I want the deeper network skills behind the fix.
        </p>
        <div class="button-row">
          <a class="button button--signal" href="#selected-work">See my work <span>↓</span></a>
          <a class="button" href="/Nazeem-Dickey-Resume.pdf" download>Download resume <span>↓</span></a>
        </div>
      </div>

      <aside class="home-brief" aria-label="Quick facts about Nazeem">
        <dl>
          <div><dt>Best fit now</dt><dd>Help desk, IT support, or network support</dd></div>
          <div><dt>Hands-on</dt><dd>Windows, hardware, DNS, Cisco IOS, Proxmox, and firewalls</dd></div>
          <div><dt>Best result</dt><dd>1st place, SkillsUSA Florida Internetworking</dd></div>
          <div><dt>Next step</dt><dd>Grow from frontline support into network and systems administration</dd></div>
        </dl>
        <p class="availability"><span aria-hidden="true"></span>{profile.availability}</p>
      </aside>
    </section>

    <dl class="home-proof" aria-label="Selected proof points">
      <div><dt>Support</dt><dd>3 real fixes documented</dd></div>
      <div><dt>Homelab</dt><dd>3 Proxmox nodes</dd></div>
      <div><dt>Cisco practice</dt><dd>5-node CML lab</dd></div>
      <div><dt>Core certifications</dt><dd>A+ / Network+ / Security+ / CySA+</dd></div>
    </dl>

    <section class="content-section" id="selected-work" aria-labelledby="work-title">
      <div class="section-heading">
        <div class="section-heading__side">
          <p class="eyebrow">Selected work</p>
          <p>Start with the support fixes, then see the network and systems work behind them.</p>
        </div>
        <div class="section-heading__main">
          <h2 id="work-title">Problems I can explain from symptom to validation.</h2>
          <a class="text-link" href="/work">All case studies →</a>
        </div>
      </div>
      <div class="project-grid">
        {featuredProjects.slice(0, 3).map((project) => <ProjectCard project={project} />)}
      </div>
    </section>

    <section class="content-section lab-section" aria-labelledby="lab-title">
      <div class="section-heading">
        <div class="section-heading__side">
          <p class="eyebrow">Current lab</p>
          <p>A simplified view. Public enough to discuss, specific enough to mean something.</p>
        </div>
        <div class="section-heading__main">
          <h2 id="lab-title">The rack is where theory gets inconvenient.</h2>
        </div>
      </div>

      <div class="lab-layout">
        <figure class="lab-map">
          <figcaption>Current topology, simplified</figcaption>
          <div class="lab-map__flow" aria-label="Internet to services topology">
            <div><strong>Edge</strong><span>OPNsense · remote access</span></div>
            <span aria-hidden="true">→</span>
            <div><strong>Network</strong><span>Managed switch · VLANs</span></div>
            <span aria-hidden="true">→</span>
            <div><strong>Compute</strong><span>Proxmox 01 · 02 · 03</span></div>
          </div>
          <ul class="lab-map__services">
            <li><span>Identity</span>Authentik and access boundaries</li>
            <li><span>Visibility</span>Wazuh, Suricata, and service monitoring</li>
            <li><span>Recovery</span>Backups, validation checks, and rollback notes</li>
          </ul>
        </figure>

        <aside class="field-note">
          <p class="eyebrow">A real failure</p>
          <h3>One switch migration took cluster quorum with it.</h3>
          <p>
            I traced the dependency path, restored connectivity, checked the cluster state, and wrote down
            the recovery order before touching the next part of the network.
          </p>
          <a class="text-link" href="/work/operated-homelab">Read the homelab case study ↗</a>
        </aside>
      </div>
    </section>

    <section class="content-section" aria-labelledby="capabilities-title">
      <div class="section-heading">
        <div class="section-heading__side">
          <p class="eyebrow">Working knowledge</p>
          <p>These are the areas I have used in real fixes, labs, and deliberate practice.</p>
        </div>
        <div class="section-heading__main">
          <h2 id="capabilities-title">What I use and can demonstrate.</h2>
        </div>
      </div>
      <div class="capability-list">
        {capabilities.map((capability) => (
          <article class="capability">
            <h3>{capability.title}</h3>
            <p>{capability.text}</p>
            <ul aria-label={capability.title + ' tools'}>
              {capability.tools.map((tool) => <li>{tool}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section experience-grid" aria-labelledby="experience-title">
      <div class="experience-intro">
        <p class="eyebrow">Experience</p>
        <h2 id="experience-title">Where I’ve used the work.</h2>
        <p>Freelance support, community volunteering, competition pressure, and a lot of self-directed practice.</p>
        <p><a class="text-link" href="/about">More about my path ↗</a></p>
      </div>
      <div class="experience-list">
        {experience.map((item) => (
          <article class="experience-item">
            <time>{item.period}</time>
            <div><h3>{item.role}</h3><p class="experience-item__org">{item.organization}</p><p>{item.text}</p></div>
          </article>
        ))}
      </div>
    </section>

    <section class="contact-panel" aria-labelledby="contact-title">
      <div><p class="eyebrow">Contact</p><h2 id="contact-title">Looking for an entry-level technician who follows the problem through?</h2></div>
      <div class="contact-panel__side">
        <p>I’m open to help desk, IT support, network support, and NOC roles in South Florida or remote.</p>
        <a class="contact-email" href={'mailto:' + profile.email}>{profile.email}</a>
        <div class="button-row"><a class="button button--signal" href={'mailto:' + profile.email}>Email me ↗</a><button class="button" type="button" data-copy-email={profile.email}>Copy email</button></div>
      </div>
    </section>
  </main>
</BaseLayout>
