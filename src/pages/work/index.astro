---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { orderedProjects } from '../../data/portfolio';
---

<BaseLayout
  title="Work | Nazeem Dickey"
  description="Support tickets and case studies across everyday troubleshooting, network infrastructure, Cisco practice, and systems work."
>
  <main id="main" tabindex="-1">
    <header class="page-hero page-hero--compact">
      <div class="page-hero__side">
        <p class="eyebrow eyebrow--signal">Work / six case studies</p>
        <p>Ordered for a recruiter: practical support first, then networking, systems, and software work.</p>
      </div>
      <h1>Start with the problem. Show the check. Confirm the fix.</h1>
    </header>

    <section class="work-index" aria-label="Portfolio case studies">
      <div class="project-grid">
        {orderedProjects.map((project) => <ProjectCard project={project} />)}
      </div>
    </section>
  </main>
</BaseLayout>
