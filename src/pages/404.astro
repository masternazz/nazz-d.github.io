---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 | Page not found" description="This portfolio route could not be found.">
  <main id="main" class="error-page" tabindex="-1">
    <div>
      <strong>404</strong>
      <h1>That page isn’t here.</h1>
      <p>It may have moved, or the address may be wrong.</p>
      <div class="button-row" style="justify-content:center">
        <a class="button button--signal" href="/">Return home ↗</a>
        <a class="button" href="/work">Browse work ↗</a>
      </div>
    </div>
  </main>
</BaseLayout>
