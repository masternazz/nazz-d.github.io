---
import { site } from '../data/site';
---

<section class="section" id="contact">
  <div class="card contact-panel">
    <span class="mini-label">Contact</span>
    <h2>Open to junior networking, SOC, NOC, MSP, help desk, and cybersecurity internships.</h2>
    <p class="lead">
      I bring documented hands-on practice, public-safe writing, and the discipline to explain what changed and why.
    </p>
    <div class="button-row">
      <a class="button" href={`mailto:${site.email}`}>Email Me</a>
      <button type="button" class="button secondary" id="copyEmailBtn">Copy Email</button>
      <a class="button secondary" href="/pages/resume.html">Resume</a>
      <a class="button secondary" href="/card.html">Digital Card</a>
      <a class="button secondary" href={site.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
      <a class="button secondary" href={site.github} target="_blank" rel="noopener noreferrer">GitHub</a>
    </div>
    <p class="contact-line" id="contactEmailText" aria-live="polite">
      {site.email} &nbsp;&bull;&nbsp; {site.location}
    </p>
  </div>
</section>

<script is:inline>
  (() => {
    const btn = document.getElementById('copyEmailBtn');
    const label = document.getElementById('contactEmailText');
    if (!btn) return;
    btn.addEventListener('click', () => {
      navigator.clipboard.writeText('nazeemdickey@masternazz.com').then(() => {
        btn.textContent = 'Copied!';
        if (label) label.textContent = 'Email copied to clipboard!';
        setTimeout(() => {
          btn.textContent = 'Copy Email';
          if (label) label.textContent = 'nazeemdickey@masternazz.com • Boynton Beach, FL';
        }, 2500);
      });
    });
  })();
</script>
