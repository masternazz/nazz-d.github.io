---
import type { Project } from '../data/portfolio';

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<article class="project-card">
  <div class="project-card__layout">
    <div class="project-card__meta">
      <span>{project.category}</span>
      <span>{project.period}</span>
    </div>
    <div class="project-card__body">
      <div class="project-card__title">
        <h3><a href={'/work/' + project.slug}>{project.title}</a></h3>
        <ul class="tag-list" aria-label="Technologies">
          {project.stack.slice(0, 4).map((item) => <li>{item}</li>)}
        </ul>
      </div>
      <p>{project.summary}</p>
      <div class="project-card__proof">
        <span>What this proves</span>
        <ul>{project.proof.slice(0, 2).map((item) => <li>{item}</li>)}</ul>
      </div>
    </div>
    <div class="project-card__actions" aria-label={project.title + ' links'}>
      <a class="text-link" href={'/work/' + project.slug}>Read case study <span aria-hidden="true">→</span></a>
      {project.artifact && (
        <a class="text-link text-link--quiet" href={project.artifact.href}>
          View evidence <span aria-hidden="true">→</span>
        </a>
      )}
      {project.repo && (
        <a class="text-link text-link--quiet" href={project.repo} target="_blank" rel="noreferrer">
          View source <span aria-hidden="true">↗</span>
        </a>
      )}
    </div>
  </div>
</article>
