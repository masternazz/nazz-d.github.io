---
type Props = {
  eyebrow: string;
  name: string;
  lead: string;
  status?: string;
};

const { eyebrow, name, lead, status = 'Open to internships & entry-level IT roles' } = Astro.props;
---

<section class="hero">
  <div>
    {status && <p class="status-dot">{status}</p>}
    <span class="eyebrow">{eyebrow}</span>
    <h1>{name}</h1>
    <p class="lead">{lead}</p>
    <div class="button-row">
      <a class="button" href="/pages/resume.html">Resume</a>
      <a class="button secondary" href="/pages/projects.html">Project Hub</a>
      <a class="button secondary" href="#contact">Contact</a>
    </div>
  </div>
  <div class="card hero-proof">
    <span class="mini-label">Fast Proof</span>
    <h2>CompTIA Trifecta + CySA+, SkillsUSA Florida gold, real homelab operations.</h2>
    <p>31+ certs &bull; 3-node Proxmox lab &bull; 10-VLAN design &bull; public writeups from real troubleshooting work.</p>
  </div>
</section>
