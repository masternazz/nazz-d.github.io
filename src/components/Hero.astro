---
type Props = {
  eyebrow: string;
  title: string;
  lead: string;
};

const { eyebrow, title, lead } = Astro.props;
---

<section class="hero">
  <div>
    <span class="eyebrow">{eyebrow}</span>
    <h1>{title}</h1>
    <p class="lead">{lead}</p>
    <div class="button-row">
      <a class="button" href="/pages/projects.html">Explore projects</a>
      <a class="button secondary" href="/pages/resume.html">View resume</a>
      <a class="button secondary" href="#contact">Contact</a>
    </div>
  </div>
  <div class="card hero-proof">
    <span class="mini-label">Current Signal</span>
    <h2>CompTIA Trifecta + CySA+, SkillsUSA Florida gold, real homelab operations.</h2>
    <p>
      This portfolio is built around proof: documented network changes, infrastructure pages, public-safe writeups, and working automation.
    </p>
  </div>
</section>
