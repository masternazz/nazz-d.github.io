---
type Props = {
  eyebrow: string;
  name: string;
  subtitle: string;
  lead: string;
  status?: string;
};

const { eyebrow, name, subtitle, lead, status = 'Open to internships & entry-level IT roles' } = Astro.props;
---

<section class="hero">
  <div>
    {status && <p class="status-dot">{status}</p>}
    <span class="eyebrow">{eyebrow}</span>
    <h1>{name}</h1>
    <h2 class="hero-subtitle">{subtitle}</h2>
    <p class="lead">{lead}</p>
    <div class="button-row">
      <a class="button" href="/pages/resume.html">Resume</a>
      <a class="button secondary" href="/pages/projects.html">Project Hub</a>
      <a class="button secondary" href="#contact">Contact</a>
    </div>
  </div>
  <div class="card hero-proof">
    <span class="mini-label">Fast Proof</span>
    <strong>SkillsUSA Florida Internetworking Gold Medal</strong>
    <p>
      Documented lab, CompTIA Trifecta + CySA+, Cisco CCST credentials, and public writeups from real troubleshooting work.
    </p>
    <ul class="proof-mini-grid" aria-label="Portfolio highlights">
      <li>31+ certs</li>
      <li>3-node lab</li>
      <li>10-VLAN design</li>
      <li>Public writeups</li>
    </ul>
  </div>
</section>
